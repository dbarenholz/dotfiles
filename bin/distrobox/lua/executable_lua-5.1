#!/bin/sh
# distrobox_binary
BOX_NAME="lua"
BIN_PATH='/usr/bin/lua-5.1'

case "${CONTAINER_ID}" in
"$BOX_NAME") exec "$BIN_PATH" "$@" ;;
"") exec "/usr/bin/distrobox-enter" -n "$BOX_NAME" -- "$BIN_PATH" "$@" ;;
*) exec distrobox-host-exec "/usr/bin/distrobox-enter" -n "$BOX_NAME" -- "$BIN_PATH" "$@" ;;
esac
